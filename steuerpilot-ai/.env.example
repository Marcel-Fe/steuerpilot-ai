# Worker-URL des Gemini-Proxys (nach `wrangler deploy` eintragen).
# Der API-Key gehört NICHT hierher, sondern als Secret in den Cloudflare-Worker.
VITE_KI_ENDPOINT=https://steuerpilot-ai-ki.<dein-subdomain>.workers.dev

# Supabase (Cloud-Login/Sync). Beide Werte aus dem Supabase-Projekt → Settings → API.
# Der Anon-Key ist öffentlich; Row Level Security schützt die Daten.
VITE_SUPABASE_URL=https://<projekt>.supabase.co
VITE_SUPABASE_ANON_KEY=<anon-public-key>
